# ── SportsQuant Environment Configuration ──────────────────────────────────
# Copy to .env and fill in values:  cp .env.example .env

# ── General ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_SERVICE_NAME=sportsquant-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── TimescaleDB ────────────────────────────────────────────────────────────
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=sportsquant
TIMESCALE_DB=sportsquant

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Apache Ignite ─────────────────────────────────────────────────────────
IGNITE_ADDRESSES=localhost:10800

# ── Discord Notifications (optional) ───────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Pinnacle API (optional) ────────────────────────────────────────────────
PINNACLE_USERNAME=
PINNACLE_PASSWORD=