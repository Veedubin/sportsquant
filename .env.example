# SportsQuant v0.2.0 environment variables
# Copy to .env for local development: cp .env.example .env

# Database connection
SPORTSQUANT_DB_HOST=timescaledb
SPORTSQUANT_DB_PORT=5432
SPORTSQUANT_DB_USER=sportsquant
SPORTSQUANT_DB_PASSWORD=sportsquant
SPORTSQUANT_DB_NAME=sportsquant

# Poller configuration (used in Phase 2)
SPORTSQUANT_POLLER_SCHEDULER=prefect
SPORTSQUANT_POLLER_ACTIVE_SPORTS=nfl,nba
SPORTSQUANT_POLLER_ODDS_API_KEY=